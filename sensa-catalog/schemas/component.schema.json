{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sensa.io/schemas/component.schema.json",
  "title": "Component",
  "description": "Unidade técnica deployável (serviço, biblioteca, banco de dados, etc)",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "sensa.io/v1alpha1"
    },
    "kind": {
      "type": "string",
      "const": "Component"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "namespace", "labels", "annotations"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$",
          "maxLength": 63
        },
        "namespace": {
          "type": "string",
          "const": "catalog"
        },
        "labels": {
          "type": "object",
          "required": ["sensa.io/owner", "sensa.io/system", "sensa.io/type", "sensa.io/environment"],
          "properties": {
            "sensa.io/owner": {
              "type": "string",
              "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$"
            },
            "sensa.io/system": {
              "type": "string",
              "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$"
            },
            "sensa.io/type": {
              "type": "string",
              "enum": ["service", "library", "database", "queue", "cache", "frontend", "other"]
            },
            "sensa.io/environment": {
              "type": "string",
              "enum": ["dev", "qa", "prod", "staging", "all"]
            }
          },
          "additionalProperties": true
        },
        "annotations": {
          "type": "object",
          "required": ["sensa.io/description"],
          "properties": {
            "sensa.io/description": {
              "type": "string",
              "minLength": 10
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "required": ["displayName", "type", "system", "owner", "lifecycle", "environments"],
      "properties": {
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["service", "library", "database", "queue", "cache", "frontend", "other"]
        },
        "system": {
          "type": "string",
          "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$"
        },
        "owner": {
          "type": "string",
          "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$"
        },
        "lifecycle": {
          "type": "string",
          "enum": ["experimental", "development", "production", "deprecated", "retired"]
        },
        "repository": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": {
              "type": "string",
              "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$"
            },
            "path": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["component", "type", "reason"],
            "properties": {
              "component": {
                "type": "string",
                "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$"
              },
              "type": {
                "type": "string",
                "enum": ["hard", "soft"]
              },
              "reason": {
                "type": "string",
                "minLength": 5
              }
            },
            "additionalProperties": false
          }
        },
        "environments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {
                "type": "string",
                "enum": ["dev", "qa", "prod", "staging"]
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "namespace": {
                "type": "string",
                "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$"
              },
              "cluster": {
                "type": "string",
                "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
