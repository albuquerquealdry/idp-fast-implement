{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sensa.io/schemas/group.schema.json",
  "title": "Group",
  "description": "Equipe ou squad",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "sensa.io/v1alpha1"
    },
    "kind": {
      "type": "string",
      "const": "Group"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "namespace", "annotations"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$",
          "maxLength": 63
        },
        "namespace": {
          "type": "string",
          "const": "catalog"
        },
        "labels": {
          "type": "object",
          "additionalProperties": true
        },
        "annotations": {
          "type": "object",
          "required": ["sensa.io/description"],
          "properties": {
            "sensa.io/description": {
              "type": "string",
              "minLength": 10
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "required": ["displayName", "type", "members", "contact"],
      "properties": {
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["team", "squad", "chapter", "guild"]
        },
        "members": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$"
          }
        },
        "contact": {
          "type": "object",
          "required": ["email"],
          "properties": {
            "email": {
              "type": "string",
              "format": "email"
            },
            "slack": {
              "type": "string",
              "pattern": "^#[a-z0-9-]+$"
            },
            "manager": {
              "type": "string",
              "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$"
            }
          },
          "additionalProperties": false
        },
        "parent": {
          "type": "string",
          "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
