{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sensa.io/schemas/repository.schema.json",
  "title": "Repository",
  "description": "Repositório Git",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "sensa.io/v1alpha1"
    },
    "kind": {
      "type": "string",
      "const": "Repository"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "namespace", "labels", "annotations"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$",
          "maxLength": 63
        },
        "namespace": {
          "type": "string",
          "const": "catalog"
        },
        "labels": {
          "type": "object",
          "required": ["sensa.io/owner", "sensa.io/type"],
          "properties": {
            "sensa.io/owner": {
              "type": "string",
              "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$"
            },
            "sensa.io/type": {
              "type": "string",
              "enum": ["application", "library", "infrastructure", "documentation", "other"]
            }
          },
          "additionalProperties": true
        },
        "annotations": {
          "type": "object",
          "required": ["sensa.io/description"],
          "properties": {
            "sensa.io/description": {
              "type": "string",
              "minLength": 10
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "required": ["displayName", "owner", "type", "url"],
      "properties": {
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$"
        },
        "type": {
          "type": "string",
          "enum": ["application", "library", "infrastructure", "documentation", "other"]
        },
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https?://"
        },
        "defaultBranch": {
          "type": "string",
          "default": "main"
        },
        "components": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
