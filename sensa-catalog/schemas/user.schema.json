{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sensa.io/schemas/user.schema.json",
  "title": "User",
  "description": "Pessoa física",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "sensa.io/v1alpha1"
    },
    "kind": {
      "type": "string",
      "const": "User"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "namespace", "annotations"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$",
          "maxLength": 63
        },
        "namespace": {
          "type": "string",
          "const": "catalog"
        },
        "labels": {
          "type": "object",
          "additionalProperties": true
        },
        "annotations": {
          "type": "object",
          "required": ["sensa.io/description"],
          "properties": {
            "sensa.io/description": {
              "type": "string",
              "minLength": 5
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "required": ["displayName", "email", "memberOf"],
      "properties": {
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "memberOf": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$"
          }
        },
        "keycloak": {
          "type": "object",
          "required": ["username", "realm"],
          "properties": {
            "username": {
              "type": "string",
              "pattern": "^[a-z0-9._-]+$"
            },
            "realm": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
